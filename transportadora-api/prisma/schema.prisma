generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  USUARIO
}

enum StatusGeral {
  ATIVO
  INATIVO
  MANUTENCAO
}

enum TipoLancamento {
  DESPESA
  FATURAMENTO
}

enum UnidadeQuantidade {
  KG
  UNIDADE
}

enum TipoImplemento {
  CARRETA
  SEMIRREBOQUE
  REBOQUE
  DOLLY
}

enum TipoCarroceria {
  BAU
  GRANELEIRO
  SIDER
  TANQUE
  PRANCHA
  OUTRO
}

enum TipoConjuntoOperacional {
  SIMPLES
  BITREM
  RODOTREM
  OUTRO
}

enum TipoCavaloMecanico {
  SIMPLES_TOCO_4X2
  TRUCADO_6X2
  TRACADO_6X4
}

model User {
  id        String        @id @default(uuid())
  nome      String
  email     String        @unique
  senha     String
  perfil    PerfilUsuario @default(USUARIO)
  ativo     Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("users")
}

model Cliente {
  id           String   @id @default(uuid())
  nome         String
  documento    String?  @unique
  telefone     String?
  email        String?
  endereco     String?
  observacoes  String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lancamentos LancamentoFinanceiro[]
  historicos  HistoricoCliente[]

  @@map("clientes")
}

model Motorista {
  id           String   @id @default(uuid())
  nome         String
  cpf          String?  @unique
  cnh          String?  @unique
  categoriaCnh String?
  validadeCnh  DateTime?
  telefone     String?
  status       StatusGeral?
  observacoes  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cavalosMecanicos CavaloMecanico[]
  lancamentos     LancamentoFinanceiro[]
  historicos      HistoricoMotorista[]

  @@map("motoristas")
}

model Caminhao {
  id          String      @id @default(uuid())
  placa       String      @unique
  marca       String?
  modelo      String?
  ano         Int?
  conjuntoId  String?
  dataColocacaoConjunto DateTime?
  dataRemocaoConjunto   DateTime?
  cor         String?
  chassi      String?     @unique
  renavam     String?     @unique
  status      StatusGeral @default(ATIVO)
  observacoes String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  conjunto       Conjunto? @relation(fields: [conjuntoId], references: [id], onDelete: SetNull)
  lancamentos     LancamentoFinanceiro[]
  historicos      HistoricoCaminhao[]

  @@index([conjuntoId])
  @@map("caminhoes")
}

model CavaloMecanico {
  id          String      @id @default(uuid())
  placa       String      @unique
  marca       String?
  modelo      String?
  ano         Int?
  tipoCavalo  TipoCavaloMecanico?
  renavam     String?     @unique
  chassi      String?     @unique
  cor         String?
  status      StatusGeral @default(ATIVO)
  motoristaId String?
  observacoes String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  motorista   Motorista? @relation(fields: [motoristaId], references: [id], onDelete: SetNull)
  conjuntos   Conjunto[]
  lancamentos LancamentoFinanceiro[]
  historicos  HistoricoCavaloMecanico[]

  @@index([motoristaId])
  @@map("cavalos_mecanicos")
}

model Implemento {
  id                String          @id @default(uuid())
  placa             String?         @unique
  tipo              TipoImplemento
  carroceria        TipoCarroceria  @default(OUTRO)
  quantidadeEixos   Int             @default(0)
  capacidadeCarga   Decimal         @default(0) @db.Decimal(12, 3)
  status            StatusGeral     @default(ATIVO)
  observacoes       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  conjuntos  ConjuntoImplemento[]
  lancamentos LancamentoFinanceiro[]
  historicos HistoricoImplemento[]

  @@map("implementos")
}

model Conjunto {
  id                    String                   @id @default(uuid())
  nome                  String
  tipo                  TipoConjuntoOperacional  @default(SIMPLES)
  cavaloMecanicoId      String
  quantidadeTotalEixos  Int                      @default(0)
  capacidadeTotal       Decimal                  @default(0) @db.Decimal(12, 3)
  status                StatusGeral              @default(ATIVO)
  justificativaSemImplemento String?
  observacoes           String?
  placa                 String?
  dollyPlaca            String?
  segundaCarretaPlaca   String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  cavaloMecanico CavaloMecanico @relation(fields: [cavaloMecanicoId], references: [id], onDelete: Restrict)
  implementos    ConjuntoImplemento[]
  caminhoesLegados Caminhao[]
  lancamentos    LancamentoFinanceiro[]
  historicos     HistoricoConjuntoOperacional[]

  @@unique([nome])
  @@index([cavaloMecanicoId])
  @@map("conjuntos")
}

model ConjuntoImplemento {
  id           String   @id @default(uuid())
  conjuntoId   String
  implementoId String
  ordem        Int      @default(1)
  dataInicio   DateTime @default(now())
  dataFim      DateTime?
  createdAt    DateTime @default(now())

  conjunto   Conjunto   @relation(fields: [conjuntoId], references: [id], onDelete: Cascade)
  implemento Implemento @relation(fields: [implementoId], references: [id], onDelete: Restrict)

  @@unique([conjuntoId, implementoId])
  @@index([implementoId])
  @@map("conjuntos_implementos")
}

model Auditoria {
  id          String   @id @default(uuid())
  entidade    String
  entidadeId  String?
  acao        String
  usuarioId   String?
  dadosAntes  Json?
  dadosDepois Json?
  createdAt   DateTime @default(now())

  @@index([entidade])
  @@index([entidadeId])
  @@index([usuarioId])
  @@index([createdAt])
  @@map("auditorias")
}

model HistoricoMotorista {
  id          String   @id @default(uuid())
  motoristaId String
  acao        String
  dadosAntes  Json?
  dadosDepois Json?
  observacoes String?
  createdAt   DateTime @default(now())

  motorista Motorista @relation(fields: [motoristaId], references: [id], onDelete: Cascade)

  @@index([motoristaId])
  @@map("historicos_motoristas")
}

model HistoricoCaminhao {
  id          String   @id @default(uuid())
  caminhaoId  String
  acao        String
  dadosAntes  Json?
  dadosDepois Json?
  observacoes String?
  createdAt   DateTime @default(now())

  caminhao Caminhao @relation(fields: [caminhaoId], references: [id], onDelete: Cascade)

  @@index([caminhaoId])
  @@map("historicos_caminhoes")
}

model HistoricoCavaloMecanico {
  id          String   @id @default(uuid())
  cavaloMecanicoId String
  acao        String
  dadosAntes  Json?
  dadosDepois Json?
  observacoes String?
  createdAt   DateTime @default(now())

  cavaloMecanico CavaloMecanico @relation(fields: [cavaloMecanicoId], references: [id], onDelete: Cascade)

  @@index([cavaloMecanicoId])
  @@map("historicos_cavalos_mecanicos")
}

model HistoricoImplemento {
  id          String   @id @default(uuid())
  implementoId String
  acao        String
  dadosAntes  Json?
  dadosDepois Json?
  observacoes String?
  createdAt   DateTime @default(now())

  implemento Implemento @relation(fields: [implementoId], references: [id], onDelete: Cascade)

  @@index([implementoId])
  @@map("historicos_implementos")
}

model HistoricoConjuntoOperacional {
  id          String   @id @default(uuid())
  conjuntoId  String
  acao        String
  dadosAntes  Json?
  dadosDepois Json?
  observacoes String?
  createdAt   DateTime @default(now())

  conjunto Conjunto @relation(fields: [conjuntoId], references: [id], onDelete: Cascade)

  @@index([conjuntoId])
  @@map("historicos_conjuntos_operacionais")
}

model HistoricoCliente {
  id          String   @id @default(uuid())
  clienteId   String
  acao        String
  dadosAntes  Json?
  dadosDepois Json?
  observacoes String?
  createdAt   DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("historicos_clientes")
}

model Fornecedor {
  id          String   @id @default(uuid())
  nome        String
  documento   String?  @unique
  telefone    String?
  email       String?
  endereco    String?
  observacoes String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lancamentos LancamentoFinanceiro[]
  historicos  HistoricoFornecedor[]

  @@map("fornecedores")
}

model HistoricoFornecedor {
  id           String   @id @default(uuid())
  fornecedorId String
  acao         String
  dadosAntes   Json?
  dadosDepois  Json?
  observacoes  String?
  createdAt    DateTime @default(now())

  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)

  @@index([fornecedorId])
  @@map("historicos_fornecedores")
}

model CategoriaFinanceira {
  id             String          @id @default(uuid())
  nome           String          @unique
  tipoLancamento TipoLancamento?
  ativo          Boolean         @default(true)
  observacoes    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  lancamentos LancamentoFinanceiro[]

  @@map("categorias_financeiras")
}

model LancamentoFinanceiro {
  id             String               @id @default(uuid())
  data           DateTime
  placa          String
  motoristaId    String
  fornecedorId   String?
  caminhaoId      String?
  cavaloMecanicoId String?
  conjuntoId     String?
  implementoId   String?
  clienteId       String?
  categoriaId     String?
  tipoLancamento  TipoLancamento
  descricao       String?
  quantidade      Decimal              @db.Decimal(12, 3)
  unidadeQuantidade UnidadeQuantidade
  valorUnitario   Decimal              @db.Decimal(14, 2)
  valorTotal      Decimal              @db.Decimal(14, 2)
  observacoes     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  motorista  Motorista   @relation(fields: [motoristaId], references: [id], onDelete: Restrict)
  fornecedor Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  caminhao    Caminhao?   @relation(fields: [caminhaoId], references: [id], onDelete: SetNull)
  cavaloMecanico CavaloMecanico? @relation(fields: [cavaloMecanicoId], references: [id], onDelete: SetNull)
  conjunto    Conjunto?   @relation(fields: [conjuntoId], references: [id], onDelete: SetNull)
  implemento  Implemento? @relation(fields: [implementoId], references: [id], onDelete: SetNull)
  cliente     Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  categoriaFinanceira CategoriaFinanceira? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  @@index([data])
  @@index([tipoLancamento])
  @@index([categoriaId])
  @@index([motoristaId])
  @@index([fornecedorId])
  @@index([caminhaoId])
  @@index([cavaloMecanicoId])
  @@index([conjuntoId])
  @@index([implementoId])
  @@index([clienteId])
  @@map("lancamentos_financeiros")
}
